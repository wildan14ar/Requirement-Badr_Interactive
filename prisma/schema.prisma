generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model SequelizeMeta {
  name String @id @unique(map: "name") @db.VarChar(255)
}

model asset_models {
  id                                   Int           @id @default(autoincrement())
  name                                 String?       @db.VarChar(255)
  manufacture_id                       Int?
  asset_type_id                        Int?
  capacity                             Float?        @db.Float
  created_by                           BigInt?
  updated_by                           BigInt?
  deleted_by                           BigInt?
  deleted_at                           DateTime?     @db.DateTime(0)
  created_at                           DateTime      @default(now()) @db.DateTime(0)
  updated_at                           DateTime      @default(now()) @db.DateTime(0)
  manufactures                         manufactures? @relation(fields: [manufacture_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "asset_models_ibfk_1")
  asset_types                          asset_types?  @relation(fields: [asset_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "asset_models_ibfk_2")
  users_asset_models_created_byTousers users?        @relation("asset_models_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "asset_models_ibfk_3")
  users_asset_models_updated_byTousers users?        @relation("asset_models_updated_byTousers", fields: [updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "asset_models_ibfk_4")
  users_asset_models_deleted_byTousers users?        @relation("asset_models_deleted_byTousers", fields: [deleted_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "asset_models_ibfk_5")

  @@index([asset_type_id], map: "asset_type_id")
  @@index([created_by], map: "created_by")
  @@index([deleted_by], map: "deleted_by")
  @@index([manufacture_id], map: "manufacture_id")
  @@index([updated_by], map: "updated_by")
}

model asset_types {
  id           Int            @id @default(autoincrement())
  name         String?        @db.VarChar(255)
  created_at   DateTime       @default(now()) @db.DateTime(0)
  updated_at   DateTime       @default(now()) @db.DateTime(0)
  type         Int?           @db.TinyInt
  asset_models asset_models[]
  assets       assets[]
}

model assets {
  id                                 Int           @id @default(autoincrement())
  serial_number                      String?       @db.VarChar(255)
  production_year                    Int?
  asset_type_id                      Int?
  entity_id                          Int?
  owners_id                          BigInt?
  maintainers_id                     BigInt?
  status                             Int?          @db.TinyInt
  created_by                         BigInt?
  updated_by                         BigInt?
  deleted_by                         BigInt?
  deleted_at                         DateTime?     @db.DateTime(0)
  created_at                         DateTime      @default(now()) @db.DateTime(0)
  updated_at                         DateTime      @default(now()) @db.DateTime(0)
  manufacture_id                     Int?
  manufactures                       manufactures? @relation(fields: [manufacture_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "asset_manufacture_id")
  asset_types                        asset_types?  @relation(fields: [asset_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "assets_ibfk_1")
  entities                           entities?     @relation(fields: [entity_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "assets_ibfk_2")
  users_assets_owners_idTousers      users?        @relation("assets_owners_idTousers", fields: [owners_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "assets_ibfk_3")
  users_assets_maintainers_idTousers users?        @relation("assets_maintainers_idTousers", fields: [maintainers_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "assets_ibfk_4")
  users_assets_created_byTousers     users?        @relation("assets_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "assets_ibfk_5")
  users_assets_updated_byTousers     users?        @relation("assets_updated_byTousers", fields: [updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "assets_ibfk_6")
  users_assets_deleted_byTousers     users?        @relation("assets_deleted_byTousers", fields: [deleted_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "assets_ibfk_7")

  @@index([manufacture_id], map: "asset_manufacture_id")
  @@index([asset_type_id], map: "asset_type_id")
  @@index([created_by], map: "created_by")
  @@index([deleted_by], map: "deleted_by")
  @@index([entity_id], map: "entity_id")
  @@index([maintainers_id], map: "maintainers_id")
  @@index([owners_id], map: "owners_id")
  @@index([updated_by], map: "updated_by")
}

model batches {
  id                BigInt              @id @default(autoincrement())
  code              String?             @db.VarChar(255)
  expired_date      DateTime?           @db.DateTime(0)
  production_date   DateTime?           @db.DateTime(0)
  deleted_at        DateTime?           @db.DateTime(0)
  created_at        DateTime            @default(now()) @db.DateTime(0)
  updated_at        DateTime            @default(now()) @db.DateTime(0)
  manufacture_id    Int?
  status            Boolean?            @default(true)
  manufactures      manufactures?       @relation(fields: [manufacture_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "batches_ibfk_1")
  new_opname_stocks new_opname_stocks[]
  stocks            stocks[]

  @@index([manufacture_id], map: "batches_ibfk_1")
  @@index([deleted_at], map: "deleted_at")
}

model biofarma_orders {
  id                    Int       @id @default(autoincrement())
  biofarma_id           Int?
  no_do                 String?   @db.VarChar(255)
  tanggal_do            DateTime? @db.DateTime(0)
  no_po                 String?   @db.VarChar(255)
  kode_area             Int?
  pengirim              String?   @db.VarChar(255)
  tujuan                String?   @db.VarChar(255)
  alamat                String?   @db.VarChar(255)
  produk                String?   @db.VarChar(255)
  no_batch              String?   @db.VarChar(255)
  expired_date          DateTime? @db.DateTime(0)
  jm_vial               Int?
  jm_dosis              Int?
  status                String?   @db.VarChar(255)
  tanggal_terima        DateTime? @db.DateTime(0)
  created_at            DateTime  @default(now()) @db.DateTime(0)
  updated_at            DateTime  @default(now()) @db.DateTime(0)
  exist_smile           Int?
  jm_vial_terima        Int?
  jm_dosis_terima       Int?
  tanggal_kirim         DateTime? @db.DateTime(0)
  biofarma_type         String?   @db.VarChar(255)
  service_type          Int?
  no_document           String?   @db.VarChar(255)
  released_date         DateTime? @db.DateTime(0)
  notes                 String?   @db.Text
  code_product_kemenkes String?   @db.VarChar(255)
  entrance_type         String?   @db.VarChar(255)
  grant_country         String?   @db.VarChar(255)
  manufacture_country   String?   @db.VarChar(255)

  @@unique([no_do, no_batch, biofarma_type], map: "biofarma_orders_unique_index")
  @@index([biofarma_type], map: "biofarma_orders_biofarma_type")
  @@index([no_do], map: "biofarma_orders_no_do")
}

model biofarma_smdv_orders {
  id                  BigInt    @id @default(autoincrement())
  biofarma_id         BigInt    @unique(map: "biofarma_smdv_orders_index")
  nomor_do            String?   @db.VarChar(255)
  tanggal_do          DateTime? @db.Date
  nomor_po            String?   @db.VarChar(255)
  kode_area           String?   @db.VarChar(255)
  pengiriman          String?   @db.VarChar(255)
  tujuan_pengiriman   String?   @db.VarChar(255)
  alamat              String?   @db.VarChar(255)
  nama_produk         String?   @db.VarChar(255)
  no_batch            String?   @db.VarChar(255)
  expired_date        DateTime? @db.Date
  jumlah_vial         Float?
  jumlah_dosis        Float?
  status              String?   @db.VarChar(255)
  tanggal_terima      DateTime? @db.DateTime(0)
  jenis_layanan       String?   @db.VarChar(255)
  nomor_surat_alokasi String?   @db.VarChar(255)
  keterangan          String?   @db.VarChar(255)
  kode_hub            String?   @db.VarChar(255)
  tipe_vaksin         String?   @db.VarChar(255)
  tanggal_pickup      DateTime? @db.DateTime(0)
  nama_smdv           String?   @db.VarChar(255)
  do_pusat            String?   @db.VarChar(255)
  created_at          DateTime  @db.DateTime(0)
  updated_at          DateTime  @db.DateTime(0)
  deleted_at          DateTime? @db.DateTime(0)
}

