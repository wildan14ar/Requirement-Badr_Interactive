  @@index([deleted_by], map: "deleted_by")
  @@index([updated_by], map: "updated_by")
}

// / The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model customer_vendors {
  customer_id                                     Int?
  vendor_id                                       Int?
  is_distribution                                 Int       @default(1) @db.TinyInt
  is_consumption                                  Int       @default(0) @db.TinyInt
  is_extermination                                Boolean   @default(false)
  created_at                                      DateTime  @default(now()) @db.DateTime(0)
  updated_at                                      DateTime  @default(now()) @db.DateTime(0)
  deleted_at                                      DateTime? @db.DateTime(0)
  entities_customer_vendors_customer_idToentities entities? @relation("customer_vendors_customer_idToentities", fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "customer_id_fk")
  entities_customer_vendors_vendor_idToentities   entities? @relation("customer_vendors_vendor_idToentities", fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "vendor_id_fk")

  @@unique([customer_id, vendor_id, is_distribution, is_consumption], map: "customer_vendors_index")
  @@index([customer_id], map: "customer_id_fk")
  @@index([vendor_id], map: "vendor_id_fk")
  @@ignore
}

model dashboard_satusehat {
  id             BigInt    @id @default(autoincrement())
  uuid           String    @db.VarChar(255)
