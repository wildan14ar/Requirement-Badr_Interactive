  code_pqs                                                    String    @db.VarChar(255)
  capacity_nett_at_plus_5_c                                   Float?    @db.Float
  capacity_nett_at_minus_20_c                                 Float?    @db.Float
  capacity_nett_at_minus_86_c                                 Float?    @db.Float
  status                                                      Boolean?  @default(true)
