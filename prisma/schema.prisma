model commitment_items {
  id                                       BigInt           @id @default(autoincrement())
  commitment_id                            BigInt
  service_type_id                          Int
  province_id                              String           @db.VarChar(255)
  material_id                              Int
  vial_quantity                            Int
  dose_quantity                            Int
  created_by                               BigInt?
  updated_by                               BigInt?
  deleted_by                               BigInt?
  created_at                               DateTime         @db.DateTime(0)
  updated_at                               DateTime         @db.DateTime(0)
  deleted_at                               DateTime?        @db.DateTime(0)
  commitments                              commitments      @relation(fields: [commitment_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "commitment_items_ibfk_1")
  service_types                            service_types    @relation(fields: [service_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "commitment_items_ibfk_2")
  provinces                                provinces        @relation(fields: [province_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "commitment_items_ibfk_3")
  master_materials                         master_materials @relation(fields: [material_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "commitment_items_ibfk_4")
  users_commitment_items_created_byTousers users?           @relation("commitment_items_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "commitment_items_ibfk_5")
  users_commitment_items_updated_byTousers users?           @relation("commitment_items_updated_byTousers", fields: [updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "commitment_items_ibfk_6")
  users_commitment_items_deleted_byTousers users?           @relation("commitment_items_deleted_byTousers", fields: [deleted_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "commitment_items_ibfk_7")

  @@index([commitment_id], map: "commitment_items_commitment_id")
  @@index([material_id], map: "commitment_items_material_id")
  @@index([province_id], map: "commitment_items_province_id")
  @@index([service_type_id], map: "commitment_items_service_type_id")
  @@index([created_by], map: "created_by")
  @@index([deleted_by], map: "deleted_by")
  @@index([updated_by], map: "updated_by")
}

