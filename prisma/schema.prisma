  users_commitments_created_byTousers users?             @relation("commitments_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "commitments_ibfk_2")
  users_commitments_updated_byTousers users?             @relation("commitments_updated_byTousers", fields: [updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "commitments_ibfk_3")
  users_commitments_deleted_byTousers users?             @relation("commitments_deleted_byTousers", fields: [deleted_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "commitments_ibfk_4")

  @@index([vendor_id], map: "commitments_vendor_id")
  @@index([created_by], map: "created_by")
  @@index([deleted_by], map: "deleted_by")
  @@index([updated_by], map: "updated_by")
}

