# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =====================================================
# Source Database (OLTP - MySQL)
# =====================================================
SOURCE_DB_HOST=10.10.0.30
SOURCE_DB_PORT=3306
SOURCE_DB_NAME=recruitment_dev
SOURCE_DB_USER=devel
SOURCE_DB_PASS=recruitment2024

# =====================================================
# Data Mart Database (OLAP - ClickHouse)
# =====================================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=datamart_badr_interactive
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# =====================================================
# Apache Superset Configuration
# =====================================================
SUPERSET_URL=http://localhost:8088
SUPERSET_SECRET_KEY=your-secret-key-here
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin

# Superset Database Connection String (for ClickHouse)
# Format: clickhouse://user:password@host:port/database
SUPERSET_CLICKHOUSE_URI=clickhouse://default:@localhost:8123/datamart_badr_interactive

# =====================================================
# Optional: VPN Configuration (if automating VPN connection)
# =====================================================
# VPN_CONFIG_PATH=path/to/your/config.ovpn
# VPN_USERNAME=recruitment
# VPN_PASSWORD=564738

# =====================================================
# Optional: Logging Configuration
# =====================================================
# LOG_LEVEL=INFO
# LOG_FILE=etl_pipeline.log
